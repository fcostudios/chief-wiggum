{
  "identifier": "default",
  "description": "Default capability set for Chief Wiggum",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:default",
    "dialog:default",
    "dialog:allow-open",
    "os:default",
    "store:default"
  ]
}
